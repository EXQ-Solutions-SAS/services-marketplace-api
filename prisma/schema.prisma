// 1. Configuración de conexión
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CLIENT
  PROVIDER
  ADMIN
}

model Category {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?
  icon        String?
  // Precio sugerido por la plataforma para esta categoría
  basePrice   Float   @default(0)

  services Service[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("categories")
}

model Service {
  id           String @id @default(uuid())
  title        String
  description  String
  // El precio que el profesional decide cobrar por hora
  pricePerHour Float

  // Relaciones
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  providerId   String
  provider     Provider @relation(fields: [providerId], references: [id])

  bookings Booking[] 

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("services")
}

// 2. Entidades Principales
model User {
  id         String  @id @default(uuid())
  firebaseId String  @unique
  email      String  @unique
  name       String?
  role       Role    @default(CLIENT)

  provider Provider?

  // Campos extra para el perfil
  phone String?
  bio   String?

  bookings Booking[] @relation("CustomerBookings")

  reviewsWritten   Review[]  @relation("WrittenReviews")
  reviewsReceived  Review[]  @relation("ReceivedReviews")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Para el borrado lógico de la cuenta

  @@map("users")
}

model Provider {
  id       String                                 @id @default(uuid())
  userId   String                                 @unique
  user     User                                   @relation(fields: [userId], references: [id])
  bio      String?
  category String // Aquí defines si es Plomero, Electricista, etc.
  location Unsupported("geography(Point, 4326)")? // POSTGIS
  active   Boolean                                @default(true)
  services Service[]
  bookings Booking[]
}

// 1. Definir el Enum arriba del todo en el schema
enum BookingStatus {
  PENDING
  ACCEPTED
  COMPLETED
  CANCELLED
}

model Booking {
  id          String        @id @default(uuid())
  
  // Relación con el Cliente
  customerId  String
  customer    User          @relation("CustomerBookings", fields: [customerId], references: [id])
  
  // Relación con el Proveedor
  providerId  String
  provider    Provider      @relation(fields: [providerId], references: [id])

  // NUEVO: Relación con el Servicio específico
  serviceId   String
  service     Service       @relation(fields: [serviceId], references: [id])

  hours       Int           @default(1) // Cantidad de horas contratadas
  totalPrice  Float         // Calculado como: service.pricePerHour * hours

  // NUEVO: Fecha de la cita
  scheduledAt DateTime

  status      BookingStatus @default(PENDING) // Ahora usa el Enum

  reviews          Review[]
  
  payment     Payment?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("bookings")
}

model Payment {
  id        String   @id @default(uuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id])
  amount    Float
  status    String // SUCCESS, FAILED, PENDING
  method    String // Stripe, PayPal, Cash
  updatedAt DateTime @updatedAt
}

model Review {
  id          String   @id @default(uuid())
  rating      Int      // 1-5
  comment     String?
  
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id])

  reviewerId  String
  reviewer    User     @relation("WrittenReviews", fields: [reviewerId], references: [id])

  revieweeId  String
  reviewee    User     @relation("ReceivedReviews", fields: [revieweeId], references: [id])

  createdAt   DateTime @default(now())

  @@unique([bookingId, reviewerId]) // Evita que una persona califique dos veces la misma cita
  @@map("reviews")
}
