// 1. Configuración de conexión
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CLIENT
  PROVIDER
  ADMIN
}

// Añade esto a tu archivo schema.prisma

model Category {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?
  icon        String? // URL para el icono/imagen de la categoría

  // Relación con Services (se creará después, pero la dejamos lista)
  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories") // Para que en la DB la tabla se llame así en minúsculas
}

// Dejamos el modelo Service "esbozado" para que la relación no de error
model Service {
  id         String   @id @default(uuid())
  title      String
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String

  // Relación con el User (Provider)
  provider   User   @relation(fields: [providerId], references: [id])
  providerId String

  @@map("services")
}

// 2. Entidades Principales
model User {
  id         String    @id @default(uuid())
  firebaseId String    @unique
  email      String    @unique
  name       String?
  role       Role      @default(CLIENT)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  provider   Provider?
  bookings   Booking[]
  reviews    Review[]
  services   Service[] //
}

model Provider {
  id       String                                 @id @default(uuid())
  userId   String                                 @unique
  user     User                                   @relation(fields: [userId], references: [id])
  bio      String?
  category String // Aquí defines si es Plomero, Electricista, etc.
  location Unsupported("geography(Point, 4326)")? // POSTGIS
  active   Boolean                                @default(true)
  bookings Booking[]
  reviews  Review[]
}

model Booking {
  id         String   @id @default(uuid())
  customerId String
  customer   User     @relation(fields: [customerId], references: [id])
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])
  status     String   @default("PENDING") // PENDING, ACCEPTED, COMPLETED, CANCELLED
  price      Float
  payment    Payment?
  createdAt  DateTime @default(now())
}

model Payment {
  id        String   @id @default(uuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id])
  amount    Float
  status    String // SUCCESS, FAILED, PENDING
  method    String // Stripe, PayPal, Cash
  updatedAt DateTime @updatedAt
}

model Review {
  id         String   @id @default(uuid())
  rating     Int
  comment    String?
  customerId String
  customer   User     @relation(fields: [customerId], references: [id])
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])
}
